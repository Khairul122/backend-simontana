        "/api/operator/evacuation-sites": {
            "post": {
                "tags": [
                    "Operator Management"
                ],
                "summary": "Add Evacuation Site",
                "description": "Endpoint untuk menambah lokasi evakuasi baru (Operator Desa).",
                "operationId": "operatorAddEvacuationSite",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "nama_lokasi",
                                    "alamat",
                                    "kapasitas"
                                ],
                                "properties": {
                                    "nama_lokasi": {
                                        "description": "Nama lokasi evakuasi",
                                        "type": "string",
                                        "example": "Pos Evakuasi Utama"
                                    },
                                    "alamat": {
                                        "description": "Alamat lengkap",
                                        "type": "string",
                                        "example": "Jl. Evakuasi No. 123"
                                    },
                                    "kapasitas": {
                                        "description": "Kapasitas maksimal",
                                        "type": "integer",
                                        "example": 500
                                    },
                                    "koordinat": {
                                        "description": "Koordinat GPS",
                                        "type": "string",
                                        "example": "-6.200000,106.816666"
                                    },
                                    "fasilitas": {
                                        "description": "Fasilitas tersedia",
                                        "type": "string",
                                        "example": "Makanan, Medis, Listrik"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Evacuation site added successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Operator add evacuation site"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "403": {
                        "description": "Forbidden - Operator access required"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
