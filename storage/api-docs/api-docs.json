        "/api/bpbd/notifications": {
            "post": {
                "tags": [
                    "BPBD Management"
                ],
                "summary": "Send BPBD Notifications",
                "description": "Endpoint untuk mengirim notifikasi ke publik (Petugas BPBD).",
                "operationId": "bpbdSendNotifications",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "judul",
                                    "pesan",
                                    "target"
                                ],
                                "properties": {
                                    "judul": {
                                        "description": "Judul notifikasi",
                                        "type": "string",
                                        "example": "Peringatan Banjir"
                                    },
                                    "pesan": {
                                        "description": "Isi pesan notifikasi",
                                        "type": "string",
                                        "example": "Warga diminta waspada terhadap potensi banjir"
                                    },
                                    "target": {
                                        "description": "Target penerima notifikasi",
                                        "type": "string",
                                        "enum": [
                                            "Semua",
                                            "Warga",
                                            "Petugas",
                                            "Admin"
                                        ],
                                        "example": "Semua"
                                    },
                                    "kategori": {
                                        "description": "Kategori notifikasi",
                                        "type": "string",
                                        "enum": [
                                            "Info",
                                            "Peringatan",
                                            "Darurat"
                                        ],
                                        "example": "Peringatan"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Notification sent successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "BPBD send notifications"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "403": {
                        "description": "Forbidden - BPBD access required"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
